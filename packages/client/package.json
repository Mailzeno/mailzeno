{
  "name": "@mailzeno/client",
  "version": "0.3.0",
  "description": "Official MailZeno JavaScript SDK",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean"
  },
  "keywords": [
    "mailzeno",
    "email",
    "smtp",
    "sdk",
    "transactional-email",
    "email-api"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mailzeno/mailzeno.git"
  },
  "bugs": {
    "url": "https://github.com/mailzeno/mailzeno/issues"
  },
  "homepage": "https://github.com/mailzeno/mailzeno#readme",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
